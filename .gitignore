.venv/
__pycache__/
*.pyc

# Demo runtime artifacts (regenerated on use)
logs/*.jsonl

# RSA keys — never commit private keys
keys/*.pem

# Per-user identities (contain PRIVATE keys) — never commit
identities/

# Shared channel: keyring (public keys) + packages in transit
channel/

# Streamlit
.streamlit/secrets.toml
